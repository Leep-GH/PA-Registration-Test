# =============================================================================
# PDP Registry Tracker — Environment Variables
# Copy this file to .env.local and fill in the values.
# =============================================================================

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

# SQLite path (dev) or PostgreSQL connection string (prod)
DATABASE_URL=file:./data/pdp-tracker.db

# 'sqlite' (default/dev) or 'postgresql' (prod)
DATABASE_TYPE=sqlite

# ---------------------------------------------------------------------------
# Admin / Scraper Security
# ---------------------------------------------------------------------------

# Secret token protecting /api/admin/trigger-scrape
# Generate with: openssl rand -hex 32
ADMIN_SCRAPE_TOKEN=

# ---------------------------------------------------------------------------
# Scraper Configuration
# ---------------------------------------------------------------------------

# URL of the DGFiP PDP registry page.
# VERIFIED 2026-03-26: https://www.impots.gouv.fr/je-consulte-la-liste-des-plateformes-agreees
# robots.txt check passed — no Disallow covering this path.
# Page structure: two <table class="table"> elements (registered + candidates).
DGFIP_PDP_URL=https://www.impots.gouv.fr/je-consulte-la-liste-des-plateformes-agreees

# User-Agent sent with every scraper HTTP request. Must include contact info per
# DGFiP respectful-scraping norms.
SCRAPER_USER_AGENT=pdp-tracker/1.0 (https://yoursite.com; contact@yoursite.com)

# Set to 'true' to enable the Playwright fallback when Cheerio returns 0 results.
# Playwright is NOT available on Vercel serverless — only enable on Railway or VPS.
# Requires 'playwright' package to be installed: npm install playwright
PLAYWRIGHT_FALLBACK=false

# ---------------------------------------------------------------------------
# Snapshot Storage
# ---------------------------------------------------------------------------

# 'local'  — writes raw HTML to ./snapshots/{date}.html   (dev default)
# 'blob'   — uploads to Vercel Blob                        (prod)
# 'db'     — not implemented in v1                         (prints warning)
SNAPSHOT_STORAGE=local

# Days to retain raw HTML snapshots before cleanup deletes them
SNAPSHOT_RETENTION_DAYS=90

# Required when SNAPSHOT_STORAGE=blob (from Vercel Blob dashboard)
BLOB_READ_WRITE_TOKEN=

# ---------------------------------------------------------------------------
# Safety Guards
# ---------------------------------------------------------------------------

# Fraction (0–1). If the freshly-parsed count drops below
# (DB count * (1 - SAFETY_DROP_THRESHOLD)), the scrape is aborted.
# Default: 0.5  (abort if more than 50% of PDPs disappear in one run)
SAFETY_DROP_THRESHOLD=0.5

# Set to 'true' to bypass the drop guard for one run (admin use only).
# Never commit or leave as 'true' in a deployed environment.
SAFETY_CHECK_OVERRIDE=false

# ---------------------------------------------------------------------------
# Notifications
# ---------------------------------------------------------------------------

# 'console' (v1 stub — logs to stdout)
# 'resend'  — requires RESEND_API_KEY + FROM_EMAIL
# 'sendgrid'— requires SENDGRID_API_KEY + FROM_EMAIL
NOTIFICATION_PROVIDER=console

# Required when NOTIFICATION_PROVIDER=resend
RESEND_API_KEY=

# Required when NOTIFICATION_PROVIDER=sendgrid
SENDGRID_API_KEY=

# Sender address for outbound emails (required when provider != console)
FROM_EMAIL=

# Admin email for dead man's switch and safety-check alerts
ADMIN_ALERT_EMAIL=

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------

# Canonical public URL — used in RSS item links, unsubscribe URLs, OG tags
NEXT_PUBLIC_APP_URL=http://localhost:3000
